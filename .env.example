# LinkedIn Job Scraper — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# To get your LinkedIn cookies:
#   1. Log into LinkedIn in your regular browser
#   2. Open DevTools (F12) → Application tab → Cookies → linkedin.com
#   3. Copy the values for 'li_at' and 'JSESSIONID'

# Required: Your LinkedIn session cookie
LI_AT_COOKIE=your_li_at_cookie_value_here

# Recommended: JSESSIONID (needed for Voyager API intercept)
# Copy the full value including the "ajax:" prefix and surrounding quotes
JSESSIONID_COOKIE=ajax:your_jsessionid_value_here

# Optional: Override search parameters (normally set in config/search_profiles.yaml)
# SEARCH_KEYWORDS=ai engineer
# SEARCH_LOCATION=Dallas, TX

# Optional: Run browser in visible mode (default: true = headless)
# HEADLESS=false
